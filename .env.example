# Azure Service Principal credentials
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to source control.

# The Application (client) ID of the Azure AD service principal
AZURE_CLIENT_ID=<your-client-id>

# The client secret value for the service principal
AZURE_CLIENT_SECRET=<your-client-secret>

# The Directory (tenant) ID of your Azure AD tenant
AZURE_TENANT_ID=<your-tenant-id>

# The Azure subscription ID to deploy resources into
AZURE_SUBSCRIPTION_ID=<your-subscription-id>
